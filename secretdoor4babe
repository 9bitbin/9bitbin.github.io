<!DOCTYPE html>
<html lang="en">
<head>
    <title>Motivation & Love for Estefany ❤️</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Kanit:wght@700&display=swap');

        body {
            margin: 0;
            overflow: hidden;
            background: black;
            font-family: 'Kanit', sans-serif;
        }

        canvas {
            position: absolute;
            top: 0;
            left: 0;
            z-index: 1;
        }

        .floating-text {
            position: absolute;
            font-size: 24px;
            font-weight: bold;
            color: white;
            text-shadow: 
                0 0 5px black, 
                0 0 10px black, 
                -2px -2px 0 black, 
                2px -2px 0 black, 
                -2px 2px 0 black, 
                2px 2px 0 black;
            opacity: 0;
            transition: opacity 1s ease-in-out;
            z-index: 3;
            pointer-events: none;
            animation: rgbText 4s linear infinite;
        }

        .shin-chan {
            position: absolute;
            width: 80px;
            height: 80px;
            opacity: 0;
            pointer-events: none;
            z-index: 4;
            transition: opacity 0.2s ease-in-out;
        }

        @keyframes rgbText {
            0% { color: red; }
            33% { color: green; }
            66% { color: blue; }
            100% { color: red; }
        }
    </style>
</head>
<body>

<canvas id="matrixCanvas"></canvas>
<canvas id="abstractCanvas"></canvas>

<script>
// ========== Canvas Setup ==========
const abstractCanvas = document.getElementById("abstractCanvas");
const abstractCtx = abstractCanvas.getContext("2d");

const matrixCanvas = document.getElementById("matrixCanvas");
const matrixCtx = matrixCanvas.getContext("2d");

function resizeCanvas() {
    abstractCanvas.width = matrixCanvas.width = window.innerWidth;
    abstractCanvas.height = matrixCanvas.height = window.innerHeight;
}
window.addEventListener('resize', resizeCanvas);
resizeCanvas();

// ========== Abstract Background Animation ==========
const particles = [];
const maxParticles = 150;

function createParticle() {
    return {
        x: Math.random() * abstractCanvas.width,
        y: Math.random() * abstractCanvas.height,
        size: Math.random() * 8 + 4,
        speedX: (Math.random() - 0.10) * 3,
        speedY: (Math.random() - 0.5) * 3,
        color: `hsl(${Math.random() * 360}, 100%, 70%)`
    };
}

for (let i = 0; i < maxParticles; i++) {
    particles.push(createParticle());
}

function drawParticles() {
    abstractCtx.clearRect(0, 0, abstractCanvas.width, abstractCanvas.height);

    particles.forEach(p => {
        p.x += p.speedX;
        p.y += p.speedY;

        if (p.x < 0 || p.x > abstractCanvas.width) p.speedX *= -1;
        if (p.y < 0 || p.y > abstractCanvas.height) p.speedY *= -1;

        abstractCtx.fillStyle = p.color;
        abstractCtx.beginPath();
        abstractCtx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        abstractCtx.fill();
    });

    requestAnimationFrame(drawParticles);
}

drawParticles();

// ========== Matrix Code Rain ==========
const matrixColumns = Math.floor(matrixCanvas.width / 10);
const drops = Array(matrixColumns).fill(1);

function drawMatrix() {
    matrixCtx.fillStyle = "rgba(0, 0, 0, 0.05)";
    matrixCtx.fillRect(0, 0, matrixCanvas.width, matrixCanvas.height);

    matrixCtx.fillStyle = "lime";
    matrixCtx.font = "8px monospace";

    for (let i = 0; i < drops.length; i++) {
        const char = String.fromCharCode(0x30A0 + Math.random() * 96);
        matrixCtx.fillText(char, i * 10, drops[i] * 10);

        if (drops[i] * 10 > matrixCanvas.height && Math.random() > 0.975) {
            drops[i] = 0;
        }
        drops[i]++;
    }

    requestAnimationFrame(drawMatrix);
}

drawMatrix();

// ========== Motivational & Love Phrases ==========
const phrases = [
    "Believe in yourself 💪",
    "We are capable of amazing things 🌟",
    "Progress, not perfection 📈",
    "Stay strong and keep going 💥",
    "Every step counts 🚶‍♂️",
    "We are worthy of greatness 👑",
    "Dream big, work hard 💼",
    "Keep shining bright ✨",
    "Challenges make you stronger 💪",
    "Stay positive, work hard, make it happen ⚡",
    "The best is yet to come 🚀",
    "Trust the process 🌀",
    "One day at a time ⏳",
    "Believe in the beauty of your dreams 🌈",
    "We are unstoppable 🔥"
];

const estefanyMessage = "Estefany, I love you ❤️";

function createFloatingText(text) {
    const span = document.createElement('span');
    span.className = 'floating-text';
    span.innerText = text;
    document.body.appendChild(span);

    const x = Math.random() * (window.innerWidth - 300);
    const y = Math.random() * (window.innerHeight - 50);
    span.style.left = `${x}px`;
    span.style.top = `${y}px`;

    setTimeout(() => span.style.opacity = 1, 100);
    setTimeout(() => {
        span.style.opacity = 0;
        setTimeout(() => span.remove(), 1000);
    }, 4000);
}

let phraseCounter = 0;

function showRandomPhrase() {
    if (phraseCounter % 5 === 0) {
        createFloatingText(estefanyMessage);
    } else {
        const phrase = phrases[Math.floor(Math.random() * phrases.length)];
        createFloatingText(phrase);
    }
    phraseCounter++;
}

setInterval(showRandomPhrase, 3000);

// Start with a few phrases
for (let i = 0; i < 5; i++) {
    setTimeout(showRandomPhrase, i * 1000);
}

// ========== Shin Chan GIF Stickers ==========
const shinChanGifs = [
    "https://media.giphy.com/media/Ywj2iCO1TOkyQ/giphy.gif",  // Example Shin Chan GIFs
    "https://media1.giphy.com/media/v1.Y2lkPTc5MGI3NjExYjcwOTI4dWlkNGE4b3F1dWx1dXFoYnppMmpsenJzaGY5azkyeDFvaSZlcD12MV9pbnRlcm5hbF9naWZfYnlfaWQmY3Q9Zw/QX1CrKhEo9NDRD6sL3/giphy.gif",
    "https://media4.giphy.com/media/v1.Y2lkPTc5MGI3NjExcWxmbWM2MGNvanJyMml5YmwwczVlZmVmZTBjcjZpNjQ3bHlieTFsZiZlcD12MV9pbnRlcm5hbF9naWZfYnlfaWQmY3Q9Zw/MWqc0k2qiD1As/giphy.gif"
];

function showShinChanSticker() {
    const img = document.createElement('img');
    img.src = shinChanGifs[Math.floor(Math.random() * shinChanGifs.length)];
    img.className = 'shin-chan';

    const x = Math.random() * (window.innerWidth - 80);
    const y = Math.random() * (window.innerHeight - 80);
    img.style.left = `${x}px`;
    img.style.top = `${y}px`;

    document.body.appendChild(img);

    setTimeout(() => img.style.opacity = 1, 50);
    setTimeout(() => img.style.opacity = 0, 500);
    setTimeout(() => img.remove(), 700);
}

setInterval(showShinChanSticker, 500);
</script>

</body>
</html>
